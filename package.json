{
  "name": "@de-mklinger/react-gitlab-client",
  "version": "1.0.0",
  "description": "A minimalist GitLab API and OIDC client for usage in React projects",
  "keywords": [
    "GitLab",
    "React",
    "Client",
    "Auth",
    "OIDC"
  ],
  "license": "MIT",
  "author": "Marc Klinger - mklinger[at]mklinger[dot]de",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "/dist/react-gitlab-client.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-gitlab-client.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite --port 3000 --strict-port",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "assert-version": "node -e 'const die=(s)=>{console.error(`Error: ${s}`); process.exit(1)}; let ev=process.env.VERSION; if (!ev) { die(\"Missing env variable VERSION\"); } if (ev.startsWith(\"v\")) { ev = ev.substring(1); } const av=require(\"./package.json\").version; if (ev != av) { die(`Expected version ${ev}, but found version ${av} in package.json`) }; console.log(`OK: ${ev}`);'"
  },
  "peerDependencies": {
    "oidc-client-ts": ">=2.4",
    "react": ">=18",
    "react-dom": ">=18",
    "react-oidc-context": ">=2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "oidc-client-ts": "^2.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-oidc-context": "^2.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-organize-imports"
    ]
  }
}
